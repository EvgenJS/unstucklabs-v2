generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  EDITOR
  SUPPORT
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
  TRIALING
}

enum PricingModel {
  ONE_TIME
  RECURRING
  FREEMIUM
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  // Admin RBAC: absence of a Membership row means "not an admin user".
  memberships          Membership[]
  subscriptions        Subscription[]
  appUserData          AppUserData[]
  promoCodeRedemptions PromoCodeRedemption[]

  @@map("users")
}

// Grants a User a role in the internal admin panel. Modeled as its own table
// (not a `role` column on User) so it can extend to per-resource scoping
// later without a migration that touches the core User table.
model Membership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  createdAt DateTime @default(now())

  @@unique([userId, role])
  @@map("memberships")
}

// Registry of sellable mini-apps.
model Product {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  subdomain    String?      @unique
  description  String?
  pricingModel PricingModel
  priceCents   Int
  currency     String       @default("USD")
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  subscriptions Subscription[]
  media         ProductMedia[]
  promoCodes    PromoCode[]

  @@map("products")
}

// Photo/video gallery content for a product, uploaded via the Admin panel
// and stored on local disk (see lib/storage.ts) -- swappable to S3-compatible
// storage later behind that same module without touching this schema.
model ProductMedia {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  type      MediaType
  position  Int       @default(0)
  createdAt DateTime  @default(now())

  @@map("product_media")
}

// Percentage-discount promo code tied to exactly one product (not store-wide,
// per the confirmed per-app selling model already used for Subscription).
// `usedCount` is incremented atomically alongside PromoCodeRedemption at
// checkout-session creation time -- not on payment webhook confirmation,
// since the real WesternBid webhook shape is still unknown. Consequence: an
// abandoned checkout still consumes one use. Acceptable for now; revisit
// once the real WesternBid adapter exists (see docs/ROADMAP.md).
model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountPercent Int
  maxUses         Int?
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  redemptions     PromoCodeRedemption[]

  @@map("promo_codes")
}

// Enforces one redemption per user via the unique constraint -- a duplicate
// insert attempt fails atomically under concurrency, no manual locking needed.
model PromoCodeRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([promoCodeId, userId])
  @@map("promo_code_redemptions")
}

// One row per user-product purchase/subscription relationship. Always scoped
// to a single Product -- no "bundle"/all-access concept, per the confirmed
// per-app selling model.
model Subscription {
  id                      String              @id @default(cuid())
  userId                  String
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId               String
  product                 Product             @relation(fields: [productId], references: [id], onDelete: Restrict)
  status                  SubscriptionStatus
  provider                String // e.g. "westernbid" -- free text, no enum lock-in while adapter is undefined
  providerCustomerId      String?
  providerSubscriptionId  String?
  providerTransactionId   String?
  currentPeriodEnd        DateTime? // null for one-time purchases
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@unique([userId, productId])
  @@index([providerSubscriptionId])
  @@map("subscriptions")
}

// Waitlist + newsletter capture. Deliberately separate from User -- most
// waitlist signups will never become full accounts.
model EmailSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  source         String? // e.g. "waitlist:unstuck-daily", "newsletter:store"
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("email_subscribers")
}

// Authored/edited via the Admin panel in Phase 3 -- never hardcoded in the
// Store app. Phase 2 only needs the schema plus a couple of seeded posts to
// exercise the public read routes. `content` is markdown, not a rich JSON
// doc -- no editor exists yet, so a structured format would be guessing at a
// shape nothing has designed for; migrating markdown -> blocks later is a
// one-time scriptable transform if Phase 3 picks a block editor.
model BlogPost {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  excerpt        String
  content        String
  coverImageUrl  String?
  status         BlogPostStatus @default(DRAFT)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("blog_posts")
}

// Lightweight capture for the landing page's "help shape what we build next"
// section -- intentionally NOT the full AI-quiz/confirmation pipeline (see
// docs/ROADMAP.md Future/Backlog), just email + free-text idea so there's a
// real destination for submissions instead of a dead-end CTA. No status
// workflow yet -- add triage states only once there's real volume to triage.
model AppRequest {
  id          String   @id @default(cuid())
  email       String
  description String
  createdAt   DateTime @default(now())

  @@map("app_requests")
}

// General support/contact inquiries from the /contact page. Separate from
// AppRequest (product ideas) and EmailSubscriber (marketing opt-in) since
// the intent is different -- someone reaching out for help or a question.
model ContactMessage {
  id        String   @id @default(cuid())
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// Generic per-mini-app user data blob. Each mini-app owns the shape of its
// own `data` JSON; core-api only enforces ownership and which product it
// belongs to, not the internal structure.
model AppUserData {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  data      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("app_user_data")
}
