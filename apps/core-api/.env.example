DATABASE_URL="postgresql://unstucklabs:unstucklabs_dev@localhost:5432/unstucklabs_dev"

# Auth
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
COOKIE_DOMAIN=".unstucklabs.com"

# Store's own URL -- core-api needs this server-side to build the
# verify-email link embedded in the verification email
# (${STORE_URL}/verify-email?token=...).
STORE_URL="http://localhost:3000"
EMAIL_VERIFICATION_TOKEN_HOURS="24"

# Email -- requires the sending domain to be verified in Resend's own
# dashboard before EMAIL_FROM can actually deliver. The verified domain for
# this account is unstucklabs.store (not unstucklabs.com), same one v1
# already used for transactional email. Without a key set, sends are logged
# (including the full body -- see email.service.ts) and skipped rather than
# throwing, so registration/verification still works locally without a real
# Resend account.
RESEND_API_KEY=""
EMAIL_FROM="UnstuckLabs <hello@unstucklabs.store>"

# Free trial (generic, any product) -- POST /apps/:productSlug/trial/start
TRIAL_DAYS="5"

# Unstuck Daily -- AI task breakdown (OpenRouter, self-serve signup at
# openrouter.ai). OPENROUTER_MODEL should be verified against
# https://openrouter.ai/models?max_price=0 -- the free-tier catalog changes.
# Named :free models (unlike the openrouter/free auto-router) also require
# enabling free-tier providers under https://openrouter.ai/settings/privacy,
# or they 404 with "No endpoints available matching your ... data policy".
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openrouter/free"
OPENROUTER_FALLBACK_MODEL="nvidia/nemotron-3-ultra-550b-a55b:free"
# Optional last-resort paid fallback if every free attempt fails. Real (tiny)
# cost per call -- leave unset to disable and only ever use free models.
OPENROUTER_PAID_FALLBACK_MODEL="nvidia/nemotron-3-ultra-550b-a55b"
UNSTUCK_DAILY_AI_DAILY_CAP="15"
# Explicit "find resources" button (opt-in, per subtask). Uses OpenRouter's
# web-search plugin, which costs real (tiny, ~$0.004-0.005/call) money on
# every call regardless of the model's own price -- separate cap from the
# main AI daily cap above so it doesn't eat into that budget.
UNSTUCK_DAILY_RESOURCES_DAILY_CAP="10"

# Unstuck Daily -- Web Push reminders. Generate a key pair locally with
# `npx web-push generate-vapid-keys` (one-time, self-serve, not ticket-gated).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@unstucklabs.com"
PUSH_REMINDER_CHECK_INTERVAL_MS="900000"
PUSH_REMINDER_THRESHOLD_HOURS="4"
PUSH_REMINDER_COOLDOWN_HOURS="20"

# HabitFlow -- AI coach + recovery-day (OpenRouter, a cheap PAID model,
# deliberately not the free tier -- sidesteps the openrouter/free congestion
# problems documented for Unstuck Daily. See docs/ROADMAP.md Phase 4+
# follow-up.
# HABITFLOW_OPENROUTER_API_KEY is optional -- a separate OpenRouter key just
# for HabitFlow, so its spend is tracked/capped independently of the shared
# OPENROUTER_API_KEY used by Unstuck Daily. Falls back to OPENROUTER_API_KEY
# if unset.
HABITFLOW_OPENROUTER_API_KEY=""
HABITFLOW_OPENROUTER_MODEL="nvidia/nemotron-3-ultra-550b-a55b"
HABITFLOW_AI_DAILY_CAP="15"
HABITFLOW_RECOVERY_DAILY_CAP="5"

# FishCast -- weather/geocoding (OpenWeatherMap, server-side only; v1 had
# this key hardcoded in frontend source, fixed here). Free tier covers
# Current Weather + 5 Day/3 Hour Forecast + Geocoding at 60 calls/min /
# 1,000,000 calls/month -- get a key at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=""
# FishCast -- AI forecast analysis (OpenRouter, a cheap PAID model, same
# reasoning as HabitFlow above). FISHCAST_OPENROUTER_API_KEY is optional --
# falls back to OPENROUTER_API_KEY if unset. The client plans to supply a
# different AI provider/model separately; swap FISHCAST_OPENROUTER_MODEL
# (and FISHCAST_OPENROUTER_API_KEY if it's a different key) once given.
FISHCAST_OPENROUTER_API_KEY=""
FISHCAST_OPENROUTER_MODEL="nvidia/nemotron-3-ultra-550b-a55b"
FISHCAST_AI_DAILY_CAP="15"
FISHCAST_FORECAST_CACHE_TTL_HOURS="12"

PORT=3001
# Defaults to all interfaces (fine for local dev). In production, set to
# 127.0.0.1 -- Nginx reverse-proxies this port, see deploy/DEPLOYMENT.md.
HOST=0.0.0.0
# Comma-separated allowed origins. Empty/unset falls back to
# DEFAULT_DEV_ORIGINS in plugins/cors.ts (localhost only) -- production
# MUST set this explicitly, e.g.:
# CORS_ORIGINS="https://unstucklabs.com,https://admin.unstucklabs.com,https://unstuck-daily.unstucklabs.com,https://habitflow.unstucklabs.com,https://fishcast.unstucklabs.com"
CORS_ORIGINS=""
